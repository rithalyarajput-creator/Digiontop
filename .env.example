# ===== DigionTop environment variables (set these in Vercel) =====

# Auto-set by the Vercel Postgres integration. You don't add this manually —
# it appears when you create a Postgres database in the Vercel Storage tab.
POSTGRES_URL=

# A long random secret for signing admin login tokens (JWT).
# Generate one, e.g.: any 40+ random characters.
JWT_SECRET=change-me-to-a-long-random-string

# A secret key to protect the one-time database setup endpoint.
# Visit /api/setup?key=THIS_VALUE once after deploy to create tables.
SETUP_KEY=change-me-to-a-secret-setup-key
