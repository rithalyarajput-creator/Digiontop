# Dependencies
node_modules/
frontend/node_modules/

# Build output
dist/
build/

# frontend/dist is deliberately NOT ignored: the site is prerendered to static
# HTML locally (Vercel's build image can't run Chrome), and Vercel serves the
# committed output. Run `npm run build` in frontend/ before pushing.

# Environment files (keep .env.example)
.env
.env.local
.env.production
frontend/.env
frontend/.env.local

# Logs
*.log
npm-debug.log*

# Editor / OS
.DS_Store
Thumbs.db
.vscode/
.idea/

# PHP admin — keep real DB credentials out of git
admin/config/database.local.php
.claude/
